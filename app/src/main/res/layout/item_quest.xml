<?xml version="1.0" encoding="utf-8"?>
<!-- item_quest.xml -->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/bg_quest_card"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="2dp"
    android:layout_marginVertical="4dp"
    app:cardBackgroundColor="@color/card_background"
    app:cardCornerRadius="12dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/neon_blue_dim"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Difficulty indicator -->
            <View
                android:id="@+id/viewDifficultyIndicator"
                android:layout_width="4dp"
                android:layout_height="40dp"
                android:layout_marginEnd="12dp"
                android:background="@drawable/bg_difficulty_bar" />

            <!-- Boss icon -->
            <TextView
                android:id="@+id/ivBossIcon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="👑"
                android:textSize="20sp"
                android:layout_marginEnd="8dp"
                android:visibility="gone" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvQuestTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    tools:text="Утренняя зарядка" />

                <TextView
                    android:id="@+id/tvQuestDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:lineSpacingMultiplier="1.3"
                    tools:text="Сделай 10 минут лёгкой зарядки" />
            </LinearLayout>
        </LinearLayout>

        <!-- Tags row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="10dp">

            <TextView
                android:id="@+id/tvQuestType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_tag"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp"
                android:textColor="@color/text_secondary"
                android:textSize="10sp"
                tools:text="ЕЖЕДНЕВНЫЙ" />

            <TextView
                android:id="@+id/tvQuestCategory"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                tools:text="💪 Фитнес" />

            <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1" />

            <TextView
                android:id="@+id/tvQuestDifficulty"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="10sp"
                android:textStyle="bold"
                tools:text="ЛЁГКИЙ" />
        </LinearLayout>

        <!-- Progress bar (optional) -->
        <ProgressBar
            android:id="@+id/progressQuest"
            style="@style/ProgressBar.Neon"
            android:layout_width="match_parent"
            android:layout_height="4dp"
            android:layout_marginTop="10dp"
            android:max="100"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tvQuestProgress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:visibility="gone"
            tools:text="5/10" />

        <!-- Reward + Complete row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="12dp">

            <TextView
                android:id="@+id/tvQuestXP"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/neon_blue"
                android:textSize="13sp"
                android:textStyle="bold"
                tools:text="+50 XP" />

            <TextView
                android:id="@+id/tvQuestCoins"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:textColor="@color/neon_gold"
                android:textSize="12sp"
                tools:text="+25 💰" />

            <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCompleteQuest"
                style="@style/Button.Neon"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="✓ Выполнено"
                android:textSize="12sp"
                android:paddingHorizontal="16dp" />
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
