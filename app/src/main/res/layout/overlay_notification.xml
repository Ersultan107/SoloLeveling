<?xml version="1.0" encoding="utf-8"?>
<!-- overlay_notification.xml -->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginTop="8dp"
    app:cardBackgroundColor="@color/card_background"
    app:cardCornerRadius="16dp"
    app:cardElevation="12dp"
    app:strokeColor="@color/neon_blue"
    app:strokeWidth="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Top row: AI name + rank + dismiss -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⚡"
                android:textSize="18sp" />

            <TextView
                android:id="@+id/tvOverlayTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:textColor="@color/neon_blue"
                android:textSize="15sp"
                android:textStyle="bold"
                android:text="ARIA" />

            <TextView
                android:id="@+id/tvOverlayRank"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:layout_marginEnd="8dp"
                android:text="E-Rank" />

            <ImageButton
                android:id="@+id/btnDismissOverlay"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Закрыть" />
        </LinearLayout>

        <!-- Message -->
        <TextView
            android:id="@+id/tvOverlayMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:lineSpacingMultiplier="1.4"
            android:text="Как ты? Есть прогресс по квестам?" />

        <!-- Escape hint -->
        <TextView
            android:id="@+id/tvEscapeHint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="@color/text_disabled"
            android:textSize="9sp"
            android:gravity="center"
            android:text="Удержи 5с или тапни 3 раза для экстренного выхода" />
    </LinearLayout>
</androidx.cardview.widget.CardView>
